# ---------------------------------------------------------------------------
# Azure AI Foundry — deployed 4-agent MULTI-AGENT WORKFLOW
# ---------------------------------------------------------------------------
# Your workflow is deployed in Foundry Agent Service as a "hosted agent". It is
# invoked by its deployed NAME over an OpenAI-compatible Responses endpoint under
# the PROJECT endpoint — there is no "asst_" id involved.
#
# Copy this file to `.env` and fill in the two required values. Until both are
# set, the app runs in SAMPLE mode using the bundled report.
#
#   cp .env.example .env

# 1) PROJECT endpoint — Foundry portal -> your Project -> Overview.
#    Format (note: services.ai.azure.com, NOT openai.azure.com):
#    https://<account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://crimecatcher.services.ai.azure.com/api/projects/<your-project>

# 2) Deployed workflow name — Foundry portal -> Agents (or Workflows) ->
#    open your deployed workflow -> copy its name (this is what you deploy it as,
#    e.g. "afc-investigation-workflow").
FOUNDRY_AGENT_NAME=<your-deployed-workflow-name>

# Optional: pin a specific deployed version (defaults to latest).
# FOUNDRY_AGENT_VERSION=

# Advanced (only change if Azure docs tell you to):
FOUNDRY_TOKEN_SCOPE=https://ai.azure.com/.default
FOUNDRY_API_VERSION=v1

# Max seconds to wait for the workflow to finish (default 900 = 15 min).
AZURE_AGENT_TIMEOUT_SECONDS=900

# ---------------------------------------------------------------------------
# Authentication — Microsoft Entra ID (no static key)
# ---------------------------------------------------------------------------
# Hosted-agent/workflow endpoints are secured with Entra ID. The backend uses
# DefaultAzureCredential, so pick ONE of:
#
#   Option A (local dev): run `az login` once in your terminal. Make sure the
#     signed-in user has access to the Foundry project (e.g. "Azure AI User").
#
#   Option B (service principal): set these three; DefaultAzureCredential uses
#     them automatically. Grant the principal access to the Foundry project.
#
# AZURE_TENANT_ID=https://crimecatcher.services.ai.azure.com/api/projects/CrimeCatcher
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Frontend origin for CORS (leave as-is for local dev)
# ---------------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173
